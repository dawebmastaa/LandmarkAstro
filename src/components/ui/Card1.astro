---
const { className = '', variant = 'default' } = Astro.props;

const variants = {
	default: "bg-base-100 border border-base-300 rounded-xl",
	bordered: "bg-base-300 border border-primary-500 rounded-lg",
	ring: 'bg-base-100 ring ring-primary-800 rounded-lg',
	shadow: "bg-base-100 rounded-lg shadow-md",
	flat: "bg-base-100 rounded-lg",
	gradient: "bg-gradient-to-br from-primary-800 to-secondary-800 rounded-lg",
	gradient2: "bg-gradient-to-bl from-secondary-800 to-primary-800 rounded-lg",
  dark: "bg-primary-900 rounded-lg shadow-md",
};
---

<div class={`p-6 ${variants[variant]} ${className}`}>
  <!-- Header slot -->
  <div class="mb-4">
    <slot name="header" />
  </div>

  <!-- Body slot (default) -->
  <div class="text-base-800">
    <slot />
  </div>

  <!-- Footer slot -->
  <div class="mt-4 pt-4 border-t border-base-300">
    <slot name="footer" />
  </div>
</div>
