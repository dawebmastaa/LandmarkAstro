    <div id="calendar-modal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-base-900 transition-opacity">
     <div class="flex min-h-full items-center justify-center p-4 bg-opacity-75">
      <div class="relative bg-primary-900 rounded-lg shadow-lg/30 max-w-4xl w-full max-h-[90vh] overflow-hidden">
       <div class="flex justify-between items-center p-4 border-b border-neutral-300 bg-base-200">
        <h3 class="text-xl font-semibold">Schedule a Call</h3>
        <button id="close-calendar" class="rounded-lg p-2 btn-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
