---
import Layout from "@/layouts/Layout.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import Images from "@/components/ui/Images.astro";
import HeroImage from "@/assets/img/newhero5.webp";
import FeatureImage from "@/assets/img/feature-1.webp";
import SolutionImage from "@/assets/img/newheroa.webp";
---

<Layout
  title="About Rule The Web | Modern Web Stack Architects"
  description="We're not another web agency. We're infrastructure architects building the modern web stack that delivers 100/100 performance scores and 80%+ margins for agencies."
  robots="index,follow"
>
    <!-- Hero Section -->
    <section class="bg-base-100">
        <div class="grid max-w-7xl px-4 py-4 sm:py-6 md:py-8 xl:py-12 lg:px-6 mx-auto lg:grid-cols-12">
            <div class="mr-auto place-self-center lg:col-span-5">
                <h1 class="max-w-2xl mb-4 text-2xl font-bold md:text-3xl xl:text-4xl leading-none tracking-tight ">We Build The Infrastructure, Not Just Websites</h1>
                <p class="max-w-2xl mb-6 font-light lg:mb-8 md:text-lg lg:text-xl">
                    While most agencies are stuck in the WordPress rat race, we're building the modern web stack
                    that delivers perfect performance scores while quadrupling agency profitability.
                    We don't design pages—we architect systems.
                </p>
                <div class="space-y-2 sm:flex sm:space-y-0 sm:space-x-4">
                    <ButtonLink href="/modern-stack-blueprint" variant="primary" size="sm">Get Our Blueprint</ButtonLink>
                    <ButtonLink href="/contact" variant="outline" size="sm">Partner With Us</ButtonLink>
                </div>
                <p class="mt-4 lg:mt-8 text-sm">🚀 47 agencies have increased margins using our infrastructure</p>
            </div>
            <div class="hidden lg:m-0 lg:col-span-7 lg:flex">
               <Images
                 src={HeroImage}
                 alt="Modern web development hero"
                 component="picture"
                 formats={['avif', 'webp']}
                 sizes="(max-width: 768px) 100vw, 1200px"
                 widths={[400, 800, 1200]}
                 className="w-full h-auto rounded-lg"
                 loading="eager"
                 fetchpriority="high"
                 />
            </div>
        </div>
    </section>

    <section class="bg-base-200">
        <div class="max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto space-y-12 lg:space-y-20 lg:px-6">
            <div class="items-center gap-8 lg:grid lg:grid-cols-2 xl:gap-16">
                <div>
                    <h2 class="mb-4 text-2xl md:text-3xl xl:text-4xl font-bold tracking-tight leading-none">The WordPress Agency Trap</h2>
                    <p class="mb-8 font-light lg:text-xl">Most agencies are trapped: charging $200+/month per client for slow, hackable WordPress sites while dealing with constant updates, plugin conflicts, and 2 AM support calls. Their margins? 20-30% on a good day.</p>
                    <ul role="list" class="pt-8 space-y-5 border-t border-primary my-7 md:text-lg">
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Razor-Thin Margins:</strong> 20-30% after hosting, maintenance, support</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight text-gray-900 dark:text-white"><strong>Performance Nightmares:</strong> 30/100 Lighthouse scores are "normal"</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Maintenance Hell:</strong> Constant updates, patches, security fixes</span>
                        </li>
                    </ul>

                    <p class="mb-8 font-light lg:text-xl">We saw this trap and asked: "What if websites could be fast, secure, and profitable—simultaneously?"</p>
                    <ButtonLink href="/agency-case-studies" variant="primary" size="md">See Agency Transformation Stories</ButtonLink>
                </div>
                <Images
                 src={FeatureImage}
                 alt="WordPress vs Modern Stack comparison: 30/100 vs 95+/100 Lighthouse scores"
                 component="picture"
                 formats={['avif', 'webp']}
                 sizes="(max-width: 768px) 100vw, 1200px"
                 widths={[400, 800, 1200]}
                 className="hidden w-full mb-4 rounded-lg lg:mb-0 lg:flex"
                 loading="lazy"
                 fetchpriority="low"
                />
            </div>
            </section>

            <section class="bg-base-300">
            <div class="max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto space-y-12 lg:space-y-20 lg:px-6 items-center gap-8 lg:grid lg:grid-cols-2 xl:gap-16">
              <Images
              src={SolutionImage}
              alt="API Factory architecture diagram showing one backend serving unlimited static sites"
              component="picture"
              formats={['avif', 'webp']}
              sizes="(max-width: 768px) 100vw, 1200px"
              widths={[400, 800, 1200]}
              className="hidden w-full mb-4 rounded-lg lg:mb-0 lg:flex"
              loading="lazy"
              fetchpriority="low"
            />
                <div>
                    <h2 class="mb-4 text-2xl md:text-3xl xl:text-4xl font-bold tracking-tight leading-none">The Empire Stack Solution</h2>
                    <p class="mb-8 font-light lg:text-xl">
                        Our "API Factory" model: One $20/month server that serves dynamic features
                        (forms, booking, CRM) to unlimited static sites. Agencies deliver 100/100
                        performance scores while keeping 80%+ margins.
                    </p>

                    <ul role="list" class="py-8 space-y-5 border-t border-primary md:text-lg">
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Radical Cost Efficiency:</strong> $20/month vs $200+ WordPress hosting</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Perfect Performance:</strong> 100/100 Lighthouse scores guaranteed</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Zero Maintenance:</strong> Static sites don't need updates or patches</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>Unhackable Architecture:</strong> Static files can't be compromised</span>
                        </li>
                        <li class="flex space-x-3">
                            <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="font-medium leading-tight"><strong>White-Label Ready:</strong> Your branding, our infrastructure</span>
                        </li>
                    </ul>
                    <p class="font-light lg:text-xl">We don't just build websites. We build the economic engine that makes web agencies profitable again.</p>
                    <div class="mt-8"><ButtonLink href="/performance-demo/" variant="primary" size="md">See API Factory Live Demo</ButtonLink></div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-base-200 border border-base-300">
        <div class="max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto text-center lg:px-6">
            <h2 class="mb-4 text-2xl md:text-3xl font-bold tracking-tight leading-none">Ready to Escape the WordPress Trap?</h2>
            <p class="mb-8 lg:text-xl font-light max-w-3xl mx-auto">Join the 47 agencies who've already increased their margins by 60%+ using our modern stack.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <ButtonLink href="/contact/" variant="primary" size="md" class="border border-white">Schedule Free Strategy Session</ButtonLink>
                <ButtonLink href="/modern-stack-blueprint/" variant="primary" size="md">Download Free Blueprint</ButtonLink>
            </div>
            <p class="mt-6 text-sm">Limited to 3 strategy sessions per week</p>
        </div>
    </section>
</Layout>
