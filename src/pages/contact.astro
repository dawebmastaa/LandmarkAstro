---
import Layout from "@/layouts/Layout.astro";
import Images from "@/components/ui/Images.astro";
import HeroImage from "@/assets/img/newhero10.webp";
import ContactModal from "@/components/ui/ContactModal.astro";
import BookingModal from "@/components/ui/BookingModal.astro";
---
<Layout
  title="Contact Rule The Web | Modern Web Solutions Consultation"
  description="Schedule a free consultation or send a message about migrating from WordPress, building modern static sites, or agency partnership opportunities."
  robots="index,follow"
>
    <!-- Hero Section -->
    <section class="bg-base-100">
        <div class="grid max-w-7xl px-4 py-4 sm:py-6 md:py-8 xl:py-12 lg:px-6 mx-auto lg:grid-cols-12">
            <div class="mr-auto place-self-center lg:col-span-5">
                <h1 class="max-w-2xl mb-4 text-2xl md:text-3xl xl:text-4xl font-extrabold leading-none tracking-tight">Let's Build Your Modern Web Stack</h1>
                <p class="max-w-2xl mb-6 font-light lg:mb-8 md:text-lg lg:text-xl">
                    Whether you're an agency looking to increase margins, a business wanting to escape WordPress bloat,
                    or a developer interested in our modern stack—we're here to help you build faster, cheaper,
                    better-performing websites.
                </p>
                <div class="space-y-2 sm:flex sm:space-y-0 sm:space-x-4">
                    <button title="A FREE no obligation callback consultation!!" id="open-calendar-btn" type="button" class="btn btn-sm btn-primary p-2">Schedule A Consultation</button>
                    <button title="Use this form to send an inquiry." id="contact-modal-btn" type="button" class="btn btn-sm btn-outline p-2">Send Quick Message</button>
                </div>
                <p class="mt-4 lg:mt-8 text-sm">⏱️ Typical response time: 2-4 hours during business days</p>
            </div>
            <div class="hidden lg:mt-0 lg:col-span-7 lg:flex">
            <Images
              src={HeroImage}
              alt="Contact Us Today! || Rule The Web"
              component="picture"
              formats={['avif', 'webp']}
              sizes="(max-width: 768px) 100vw, 1200px"
              widths={[400, 800, 1200]}
              className="w-full h-auto rounded-lg"
              loading="eager"
              fetchpriority="high"
            />
            </div>
        </div>
    </section>

    <!-- Testimonial -->
    <section class="bg-base-200 border-y border-base-300">
        <div class="max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto text-center lg:px-6">
            <figure class="max-w-3xl mx-auto">
                <svg class="h-8 md:h-12 mx-auto mb-3 text-base-400" viewBox="0 0 24 27" fill="none">
                    <path d="M14.017 18L14.017 10.609C14.017 4.905 17.748 1.039 23 0L23.995 2.151C21.563 3.068 20 5.789 20 8H24V18H14.017ZM0 18V10.609C0 4.905 3.748 1.038 9 0L9.996 2.151C7.563 3.068 6 5.789 6 8H9.983L9.983 18L0 18Z" fill="currentColor"></path>
                </svg>
                <blockquote><p class="text-md md:text-xl">"The migration consultation saved us $4,200/month in hosting costs alone.Their modern stack blueprint was exactly what our agency needed to stay competitive."</p></blockquote>
                <figcaption class="flex items-center justify-center mt-6 space-x-3">
                    <img class="w-8 h-8 rounded-full" src="https://gravatar.com/userimage/98702177/66460bceea4ae0fec9c1de70910bd9af.jpeg?size=64" alt="Agency owner testimonial" loading="lazy" />
                    <div class="flex items-center divide-x-2">
                        <div class="pr-3 font-semibold">Sarah K.</div>
                        <div class="pl-3 text-sm font-light">Agency Owner, 25+ client sites migrated</div>
                    </div>
                </figcaption>
            </figure>
        </div>
    </section>

<ContactModal />
<BookingModal />
</Layout>
