---
import Layout from "@/layouts/Layout.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import Images from "@/components/ui/Images.astro";
import HeroImage from "@/assets/img/newhero6.webp";
import GraphImage from "@/assets/img/feature-1.webp";
---

<Layout
  title="Escape WordPress Bloat | Modern Static Websites That Actually Perform"
  description="Stop overpaying for slow, hackable WordPress sites. Get 100/100 Lighthouse scores for $20/month with our modern static site stack. Free blueprint download."
  robots="index,follow"
>
<!-- Hero Section -->
  <section class="bg-base-100">
        <div class="grid max-w-7xl px-4 py-4 sm:py-6 md:py-8 xl:py-12 lg:px-6 mx-auto lg:grid-cols-12">
            <div class="mr-auto place-self-center lg:col-span-5">
            <h1 class="max-w-2xl mb-4 text-2xl md:text-3xl xl:text-4xl font-bold leading-none tracking-tight">The Modern Web Stack That Delivers 100/100 Performance & 80%+ Margins</h1>
            <p class="max-w-2xl mb-6 font-light lg:mb-8 md:text-lg lg:text-xl">
                While most agencies struggle with bloated tech stacks and razor-thin margins,
                we've built a lean system that delivers perfect Lighthouse scores while
                quadrupling your profitability. No complexity, just results.
            </p>
            <div class="space-y-2 sm:flex sm:space-y-0 sm:space-x-4">
                <ButtonLink href="/modern-stack-blueprint" variant="primary" size="sm">Get The Blueprint</ButtonLink>
                <ButtonLink href="/performance-demo" variant="outline" size="sm">See Performance Demo</ButtonLink>
            </div>
            <p class="mt-4 lg:mt-8 text-sm">⚡ 47 agencies increased margins by 60%+ using our stack</p>
        </div>
        <div class="hidden lg:m-0 lg:col-span-7 lg:flex">
            <Images
              src={HeroImage}
              alt="Modern web development hero"
              component="picture"
              formats={['avif', 'webp']}
              sizes="(max-width: 768px) 100vw, 1200px"
              widths={[400, 800, 1200]}
              className="w-full h-auto rounded-full"
              loading="eager"
              fetchpriority="high"
            />
        </div>
    </div>
  </section>

  <section class="bg-base-300">
        <div class="max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto lg:px-6">
            <div class="items-center gap-8 lg:grid lg:grid-cols-2 xl:gap-16">
                <div>
                <h2 class="mb-4 text-2xl md:text-3xl xl:text-4xl font-bold tracking-tight leading-none">Why Modern Agencies Choose Our Stack</h2>
                <p class="max-w-2xl mb-6 font-light lg:mb-8 md:text-lg lg:text-xl">Traditional web development has become a race to the bottom. Our "API Factory" model flips the script: deliver better-performing sites at lower cost while keeping the difference as pure profit.</p>

                <ul role="list" class="space-y-5 border-t border-base-300 my-7">
                    <li class="flex space-x-3">
                        <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-base font-medium leading-tight"><strong>Performance-First Architecture:</strong> 100/100 Lighthouse scores as standard</span>
                    </li>
                    <li class="flex space-x-3">
                        <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-base font-medium leading-tight"><strong>Radical Cost Efficiency:</strong> 90% lower infrastructure costs</span>
                    </li>
                    <li class="flex space-x-3">
                        <svg class="shrink-0 w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-base font-medium leading-tight"><strong>Zero-Maintenance Operation:</strong> No updates, patches, or emergency fixes</span>
                    </li>
                </ul>

                <p class="max-w-2xl mb-6 font-light lg:mb-8 md:text-lg lg:text-xl">We partner with forward-thinking agencies to implement this stack as their white-label solution. You get the results, we handle the infrastructure.</p>
                <ButtonLink href="/" variant="primary" size="md">Explore Agency Partnership</ButtonLink>
            </div>
            <Images
              src={GraphImage}
              alt="Dashboard showing agency profitability increase from 20% to 80% margins"
              component="picture"
              formats={['avif', 'webp']}
              sizes="(max-width: 768px) 100vw, 1200px"
              widths={[400, 800, 1200]}
              className="hidden w-full mb-4 rounded-lg lg:mb-0 lg:flex"
              loading="lazy"
              fetchpriority="high"
            />
        </div>
    </div>
  </section>

  <section class="bg-base-200 border-b border-base-300">
  <div class="max-w-7xl mx-auto container py-6 sm:py-8 md:py-10 xl:py-14">
    <div class="flex flex-col md:flex-row">
        <div class="flex flex-col justify-center w-full md:w-1/2 px-4 md:pr-12">
            <p class="uppercase text-lg text-primary font-semibold leading-normal">THE EMPIRE STACK</p>
            <h2 class="text-2xl md:text-3xl xl:text-4xl font-bold leading-none py-4">One $20/Month API Serves Unlimited Client Sites</h2>
            <p class="mt-3 lg:mb-8 md:text-lg lg:text-xl font-light">
                Traditional web dev charges per site. Our "API Factory" model serves dynamic features
                (forms, bookings, CRM) to unlimited static sites from a single $20/month server.
                Agencies keep the difference as pure profit.
            </p>

            <div class="mt-8 space-y-4">
                <div class="flex items-start">
                    <svg class="w-6 h-6 text-primary mt-1 mr-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <div>
                        <h3 class="font-bold">Static Frontends</h3>
                        <p>Free hosting on GitHub Pages/Cloudflare</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <svg class="w-6 h-6 text-primary mt=1 mr-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <div>
                        <h3 class="font-bold">Single API Backend</h3>
                        <p>$20/month server handles all dynamic features</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <svg class="w-6 h-6 text-primary mt-1 mr-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <div>
                        <h3 class="font-bold">Agency White Label</h3>
                        <p>Your branding, our infrastructure</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid place-items-center bg-primary-800 w-full md:w-1/2 px-4 md:px-12 py-10 mt-8 md:mt-0 md:rounded-lg shadow-lg text-white">
            <div class="text-center mb-4">
                <h3 class="text-2xl font-bold mb-2">Free Download</h3>
                <p class="">WordPress Escape Blueprint</p>
            </div>

            <div class="space-y-6">
                <div class="flex items-start">
                    <div class="bg-white/20 p-2 rounded-lg mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z"></path>
                            <rect x="3" y="4" width="18" height="4" rx="2"></rect>
                            <path d="M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-10"></path>
                            <line x1="10" y1="12" x2="14" y2="12"></line>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold">Migration Checklist</h4>
                        <p class="text-sm mt-1">Step-by-step WordPress to static site migration</p>
                    </div>
                </div>

                <div class="flex items-start">
                    <div class="bg-white/20 p-2 rounded-lg mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z"></path>
                            <polyline points="7 8 3 12 7 16"></polyline>
                            <polyline points="17 8 21 12 17 16"></polyline>
                            <line x1="14" y1="4" x2="10" y2="20"></line>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold">Cost Comparison Calculator</h4>
                        <p class="text-sm mt-1">See exactly how much you'll save monthly</p>
                    </div>
                </div>

                <div class="flex items-start">
                    <div class="bg-white/20 p-2 rounded-lg mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z"></path>
                            <rect x="3" y="4" width="18" height="12" rx="1"></rect>
                            <line x1="7" y1="20" x2="17" y2="20"></line>
                            <line x1="9" y1="16" x2="9" y2="20"></line>
                            <line x1="15" y1="16" x2="15" y2="20"></line>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold">Agency Partnership Template</h4>
                        <p class="text-sm mt-1">White-label agreement for scaling your agency</p>
                    </div>
                </div>
            </div>

            <div class="mt-8 text-center">
                <ButtonLink href="/" size="md" class="w-full">Download Free Blueprint (PDF)</ButtonLink>
                <p class="text-sm mt-2">127 downloads this week</p>
            </div>
        </div>
    </div>
  </div>
</section>

<section class="bg-base-100">
  <div class="items-center max-w-7xl px-4 py-6 sm:py-8 md:py-10 xl:py-14 mx-auto lg:grid lg:grid-cols-4 lg:gap-16 xl:gap-24 lg:px-6">
    <div class="col-span-2 mb-8">
      <p class="text-lg font-medium text-primary">Proven Business Model</p>
      <h2 class="mt-3 max-w-2xl mb-4 text-2xl font-bold leading-none tracking-tight md:text-3xl">Agencies Adding $5k/Month With Our Stack</h2>
      <p class="max-w-2xl mb-4 font-light lg:mb-6 md:text-lg lg:text-xl">While WordPress agencies struggle with 20% margins, our partners average 80% margins by eliminating hosting costs and maintenance overhead.</p>
      <div class="pt-6 mt-6 space-y-4 border-t border-base-300">
        <div><a href="/" class="inline-flex items-center text-base font-medium text-primary hover:opacity-80">View Agency Case Studies <svg class="w-5 h-5 ml-1" fill="currentColor" viewBox="0 0 20 20"> <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path> </svg></a></div>
        <div><a href="/" class="inline-flex items-center text-base font-medium text-primary hover:opacity-80">Calculate Your Savings <svg class="w-5 h-5 ml-1" fill="currentColor" viewBox="0 0 20 20"> <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path> </svg></a></div>
      </div>
    </div>
    <div class="col-span-2 space-y-8 sm:grid sm:grid-cols-2 sm:gap-4 sm:space-y-0">
      <div>
        <div class="w-10 h-10 mb-2 text-primary md:w-12 md:h-12"><span class="text-2xl font-bold">90%</span></div>
        <h3 class="max-w-2xl mb-2 text-2xl font-bold leading-none tracking-tight md:text-3xl">Lower Hosting Costs</h3>
        <p class="font-light">$20 vs $200+ monthly hosting savings</p>
      </div>
      <div>
        <div class="w-10 h-10 mb-2 text-primary md:w-12 md:h-12"><span class="text-2xl font-bold">47</span></div>
        <h3 class="max-w-2xl mb-2 text-2xl font-bold leading-none tracking-tight md:text-3xl">Agencies Migrated</h3>
        <p class="font-light">From WordPress to our stack in 2024</p>
      </div>
      <div>
        <div class="w-10 h-10 mb-2 text-primary md:w-12 md:h-12"><span class="text-2xl font-bold">95+/100</span></div>
        <h3 class="max-w-2xl mb-2 text-2xl font-bold leading-none tracking-tight md:text-3xl">Performance Scores</h3>
        <p class="font-light">Average Lighthouse score guarantee</p>
      </div>
      <div>
        <div class="w-10 h-10 mb-2 text-primary md:w-12 md:h-12"><span class="text-2xl font-bold">0</span></div>
        <h3 class="max-w-2xl mb-2 text-2xl font-bold leading-none tracking-tight md:text-3xl">Security Breaches</h3>
        <p class="font-light">Static sites don't get hacked</p>
      </div>
    </div>
  </div>
</section>

<section class="bg-base-200 border-y border-base-300">
  <div class="max-w-7xl px-4 py-8 mx-auto text-center lg:py-20 lg:px-6">
    <figure class="max-w-3xl mx-auto">
      <svg class="h-8 md:h-12 mx-auto mb-3 text-base-400" viewBox="0 0 24 27" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14.017 18L14.017 10.609C14.017 4.905 17.748 1.039 23 0L23.995 2.151C21.563 3.068 20 5.789 20 8H24V18H14.017ZM0 18V10.609C0 4.905 3.748 1.038 9 0L9.996 2.151C7.563 3.068 6 5.789 6 8H9.983L9.983 18L0 18Z" fill="currentColor"></path>
      </svg>
      <blockquote><p class="text-md lg:text-lg font-medium">"In {new Date().getFullYear()} it makes absolutely NO sense to be developing sites with Wordpress. Modern sites are faster, cheaper and are less headache to maintain. Why pay $30-50/mo or more for hosting when you can have a faster site for almost nothing"</p></blockquote>
      <figcaption class="flex items-center justify-center mt-6 space-x-3">
        <img class="w-10 h-10 rounded-full" src="https://gravatar.com/userimage/98702177/66460bceea4ae0fec9c1de70910bd9af.jpeg?size=64" alt="Mike A., Agency Owner" loading="lazy" />
        <div class="flex items-center divide-x-2 divide-base-500">
          <div class="pr-3 font-semibold">Mike A.</div>
          <div class="pl-3 text-sm font-light">Web Developer, 30+ years experience</div>
        </div>
      </figcaption>
    </figure>

    <div class="mt-6">
      <ButtonLink href="/contact" variant="primary" size="lg">Schedule Free Assessment</ButtonLink>
      <p class="mt-4 text-sm">Limited to 3 assessments per week</p>
    </div>
  </div>
</section>
</Layout>
